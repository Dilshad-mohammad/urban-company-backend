{
  "name": "urbanclap-backend",
  "version": "1.0.0",
  "description": "Node.js Express backend for Urban Company clone - Home Services Marketplace",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --detectOpenHandles",
    "test:unit": "node --test tests/**/*.test.js",
    "seed": "node scripts/seed.js",
    "lint": "eslint src/ || true",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "home-services",
    "marketplace",
    "urban-company",
    "node",
    "express",
    "mongodb"
  ],
  "author": "UrbanClap Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "firebase-admin": "^13.8.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.6.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "axios": "^1.14.0",
    "eslint": "^8.54.0",
    "form-data": "^4.0.5",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
